		if # a ~= # d or table.concat(a) ~= table.concat(d) then
			d = a;
			b:Refresh(d)
		end
	end;
	a:button({
		Name = "create",
		Callback = function()
			pcall(function()
				local a = n.flags["cfg_name"]
				if a ~= "" and not isfile("CONFIGS/" .. a .. ".cfg") then
					writefile("CONFIGS/" .. a .. ".cfg", n:GetConfig())
					n:Notification("Created config [" .. a .. "].", 5, Color3.new(0, 1, 1))
					e()
				end
			end)
		end
	})
	a:button({
		Name = "save",
		Callback = function()
			pcall(function()
				local a = n.flags["cfg_list"]
				if a then
					writefile("CONFIGS/" .. a .. ".cfg", n:GetConfig())
					n:Notification("Saved config [" .. a .. "].", 5, Color3.new(1, 1, 0))
					e()
				end
			end)
		end
	})
	a:button({
		Name = "load",
		Callback = function()
			pcall(function()
				local a = n.flags["cfg_list"]
				if a then
					n:LoadConfig(readfile("CONFIGS/" .. a .. ".cfg"))
					n:Notification("Loaded config [" .. a .. "].", 5, Color3.new(0, 1, 0))
					e()
				end
			end)
		end
	})
	a:button({
		Name = "delete",
		Callback = function()
			pcall(function()
				local a = n.flags["cfg_list"]
				if a then
					delfile("CONFIGS/" .. a .. ".cfg")
					n:Notification("Deleted config [" .. a .. "].", 5, Color3.new(1, 0, 0))
					e()
				end
			end)
		end
	})
	e()
end;
