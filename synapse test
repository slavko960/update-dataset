function n:LoadTheme(themeName)
	if not self.themes[themeName] then return end
	self.currentTheme = themeName
	local theme = self.themes[themeName]
	-- переприменяем цвета ко всем зарегистрированным instance
	for inst, data in pairs(self.instancemap) do
		if inst and inst.Parent then
			for prop, colorKey in pairs(data.Properties) do
				local color = theme[colorKey]
				if color then
					inst[prop] = color
				end
			end
		end
	end
end;
function n:AttachTheme(inst, props)
	local theme = self.themes[self.currentTheme or "Blue"]
	if not theme then return end
	self.instancemap[inst] = { Instance = inst, Properties = props }
	for prop, colorKey in pairs(props) do
		local color = theme[colorKey]
		if color then
			inst[prop] = color
		end
	end
end;
function n:GetSelectedThemeAndAccent()
